{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "d2t-detect",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-01",

  // Statický frontend servíruje tentýž Worker co API -> stejný origin, žádné
  // CORS, jeden deploy. run_worker_first vynutí, aby /api/* šlo na Worker a ne
  // do statických assetů. not_found_handling nikdy nenastavovat na "single-
  // page-application" - vracelo by index.html i na /api/* a API by tiše umřelo.
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "404-page"
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "d2t-detect",
      // PLACEHOLDER - lokální `wrangler dev` jen potřebuje neprázdnou hodnotu.
      // PŘED nasazením nahraď skutečným id z `wrangler d1 create d2t-detect`
      // (viz README), jinak deploy míří na neexistující DB.
      "database_id": "00000000-0000-0000-0000-000000000000",
      "migrations_dir": "migrations"
    }
  ],

  // Brzda na brute-force login/registrace. period smí být jen 10 nebo 60 s.
  // Per-colo a eventually consistent -> zmírnění, ne bezpečnostní hranice.
  // Middleware je no-op, když binding chybí (testy, `wrangler dev`).
  "ratelimits": [
    {
      "name": "AUTH_LIMITER",
      "namespace_id": "2001",
      "simple": { "limit": 10, "period": 60 }
    }
  ],

  "vars": {
    // PBKDF2 je na Workers zastropované na 100k iterací a free plan má 10 ms
    // CPU/request. Slabší než serverový bcrypt/argon2 - daň za free tier.
    "PBKDF2_ITERATIONS": "100000"
  },

  "observability": { "enabled": true }
}
