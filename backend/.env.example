# Zkopíruj do .env (gitignored) a doplň skutečné hodnoty.
# Prázdné hodnoty jsou v pořádku pro lokální vývoj - Stripe pak spadne
# zpět na fake platbu a Sentry se nezapne.

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=czk

SENTRY_DSN=

# Zákaznický chatbot (Claude Haiku). Bez klíče /api/chat/ vrátí 503.
ANTHROPIC_API_KEY=
